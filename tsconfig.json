{
  "compilerOptions": {
    "moduleResolution": "Bundler",
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist",
    "outDir": "dist",
    "module": "esnext",
    "target": "esnext",
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["src", "demo", "util"]
}