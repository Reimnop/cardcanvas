{
  "name": "cardcanvas",
  "version": "1.0.0",
  "description": "Canvas rendering library for Afterbeat prefab cards",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Reimnop/cardcanvas"
  },
  "author": {
    "name": "Reimnop"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "build:wasm": "tsx util/build-wasm.ts",
    "build:js": "tsup src/**/*.ts --format esm --dts --splitting --out-dir dist",
    "build": "npm run build:wasm && npm run build:js",
    "demo": "tsx demo/index.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "sharp": "^0.35.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
